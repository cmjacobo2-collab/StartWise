<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>StartWise — Your 12-Week Business Launch Planner</title>

  <!-- PWA / installable app -->
  <meta name="theme-color" content="#1B344F" />
  <meta name="description" content="Plan, budget, price, and grow your small business — from idea to launch and beyond. By Across the Table." />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="StartWise" />
  <link rel="manifest" href="manifest.webmanifest" />
  <link rel="icon" type="image/png" href="icons/icon-192.png" />
  <link rel="apple-touch-icon" href="icons/apple-touch-icon.png" />

  <!-- Resources referenced as strings in JSX (bundler can't auto-discover these) -->
  <meta name="ext-resource-dependency" content="assets/logo.png" data-resource-id="logo" />

  <!-- Across the Table design system -->
  <link rel="stylesheet" href="_ds/across-the-table-design-system-52082246-cccd-4b7c-b721-c75c41bcccd7/styles.css" />

  <style>
    /* Remap near-black backgrounds & text colors to #091D30 */
    :root {
      --ink-900: #091D30;
      --navy-950: #091D30;
      --navy-900: #091D30;
      --text-strong: #091D30;
      --bg-dark: #091D30;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--cream-50);
      color: var(--text-body);
      font-family: var(--font-sans);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }
    #root { min-height: 100vh; }
    button { font-family: var(--font-sans); }
    input, select, textarea { font-family: var(--font-sans); }
    ::selection { background: var(--gold-100); }
    /* slim scrollbars */
    *::-webkit-scrollbar { width: 10px; height: 10px; }
    *::-webkit-scrollbar-thumb { background: var(--sand-300); border-radius: 999px; border: 2px solid var(--cream-50); }
    *::-webkit-scrollbar-track { background: transparent; }

    /* density tweak — overrides inline table padding */
    [data-density="compact"] table td { padding-top: 7px !important; padding-bottom: 7px !important; }
    [data-density="compact"] table { font-size: 12.5px !important; }

    button:hover { filter: brightness(0.97); }
    a { color: var(--text-link); }
    @keyframes sw-spin { to { transform: rotate(360deg); } }
  </style>

  <!-- React + Babel (pinned) -->
  <script src="https://unpkg.com/react@18.3.1/umd/react.development.js" integrity="sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js" integrity="sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" integrity="sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y" crossorigin="anonymous"></script>

  <!-- design system bundle (plain JS) + data (plain JS) -->
  <script src="_ds/across-the-table-design-system-52082246-cccd-4b7c-b721-c75c41bcccd7/_ds_bundle.js"></script>
  <script src="js/data.js?v=5"></script>
  <script src="js/source-data.js"></script>
  <script src="js/affirmations.js"></script>
  <script src="js/knowledge-data.js"></script>
  <script src="js/biz-data.js?v=5"></script>
  <script src="js/vendor-library.js?v=5"></script>
  <script src="js/task-catalog.js?v=5"></script>
</head>
<body style="font-family: &quot;Segoe UI&quot;">
  <div id="root"></div>

  <!-- Splash / no-JS fallback used by the offline single-file build -->
  <template id="__bundler_thumbnail">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
      <rect width="512" height="512" fill="#FBF8F2"/>
      <rect x="154" y="154" width="204" height="204" rx="46" fill="#1B344F"/>
      <text x="256" y="246" font-family="Arial, sans-serif" font-weight="800" font-size="96" fill="#FBF8F2" text-anchor="middle" dominant-baseline="middle">SW</text>
      <rect x="218" y="300" width="76" height="12" rx="6" fill="#C8962E"/>
    </svg>
  </template>

  <!-- app modules (JSX) -->
  <script type="text/babel" src="js/tweaks-panel.jsx"></script>
  <script type="text/babel" src="js/charts.jsx?v=5"></script>
  <script type="text/babel" src="js/shell.jsx?v=10"></script>
  <script type="text/babel" src="js/ai-setup.jsx?v=5"></script>
  <script type="text/babel" src="js/auth.jsx?v=8"></script>
  <script type="text/babel" src="js/screens-core.jsx?v=5"></script>
  <script type="text/babel" src="js/screens-more.jsx?v=7"></script>
  <script type="text/babel" src="js/screens-extra.jsx?v=5"></script>
  <script type="text/babel" src="js/screens-finance.jsx?v=5"></script>
  <script type="text/babel" src="js/screens-revenue.jsx?v=5"></script>
  <script type="text/babel" src="js/app.jsx?v=5"></script>

  <!-- Register service worker for offline / installability -->
  <script>
    if ("serviceWorker" in navigator) {
      var swRefreshing = false;
      navigator.serviceWorker.addEventListener("controllerchange", function () {
        if (swRefreshing) return; swRefreshing = true; window.location.reload();
      });
      window.addEventListener("load", function () {
        navigator.serviceWorker.register("service-worker.js").then(function (reg) {
          reg.update();
          if (reg.waiting) reg.waiting.postMessage("skipWaiting");
          reg.addEventListener("updatefound", function () {
            var nw = reg.installing;
            if (nw) nw.addEventListener("statechange", function () {
              if (nw.state === "installed" && navigator.serviceWorker.controller) nw.postMessage("skipWaiting");
            });
          });
        }).catch(function () {});
      });
    }
  </script>
</body>
</html>
